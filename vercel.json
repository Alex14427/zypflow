{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/scrape/cron",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/automations/reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/automations/follow-up",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/automations/lifecycle",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/automations/review-request",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/outreach/cron",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/automations/execute",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/automations/watchdog",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/automations/lead-score-refresh",
      "schedule": "0 3 * * *"
    }
  ]
}
